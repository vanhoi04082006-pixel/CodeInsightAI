# CodeInsight AI — Environment Variables
# Copy this file to `.env` and adjust as needed.
# On Windows (cmd):  copy .env.example .env
# On Windows (PS):   Copy-Item .env.example .env
# On macOS/Linux:    cp .env.example .env

# SQLite database location (relative to project root).
# Prisma will create the file on first `bun run db:push`.
DATABASE_URL=file:./db/custom.db
# Mật khẩu dùng để mã hóa session (Bạn có thể gõ chuỗi ngẫu nhiên bất kỳ)
NEXTAUTH_SECRET="codeinsight_super_secret_key_12345"
NEXTAUTH_URL="http://localhost:3000"

# --- LẤY TỪ GITHUB DEVELOPER SETTINGS ---
# https://github.com/settings/developers
GITHUB_ID="điền-client-id-của-bạn"
GITHUB_SECRET="điền-client-secret-của-bạn"

# --- LẤY TỪ GOOGLE CLOUD CONSOLE ---
GOOGLE_ID="điền-client-id-của-bạn"
GOOGLE_SECRET="điền-client-secret-của-bạn"