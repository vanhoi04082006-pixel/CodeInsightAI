# CodeInsight AI — Environment Variables
# Copy this file to `.env` for local development.
# On Windows (cmd):  copy .env.example .env
# On Windows (PS):   Copy-Item .env.example .env
# On macOS/Linux:    cp .env.example .env

# ═══════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT (SQLite)
# ═══════════════════════════════════════════════════════════
# For local dev, SQLite works fine. Prisma creates the file on first `bun run db:push`.
DATABASE_URL="file:./db/custom.db"

# ═══════════════════════════════════════════════════════════
# VERCEL DEPLOYMENT (PostgreSQL required)
# ═══════════════════════════════════════════════════════════
# Vercel doesn't support SQLite (filesystem is read-only on serverless).
# Use a PostgreSQL database (Vercel Postgres, Supabase, Neon, Railway, etc.)
#
# Option 1: Vercel Postgres (built-in)
#   - Go to Vercel Dashboard → Your Project → Storage → Create Postgres
#   - Copy the connection string to DATABASE_URL env var
#
# Option 2: Supabase (free tier)
#   - Go to https://supabase.com → Create project
#   - Settings → Database → Connection string
#   - Set DATABASE_URL to: postgresql://user:pass@host:5432/dbname
#
# Option 3: Neon (free tier, serverless Postgres)
#   - Go to https://neon.tech → Create project
#   - Copy connection string to DATABASE_URL
#
# After setting DATABASE_URL on Vercel, update prisma/schema.prisma:
#   datasource db { provider = "postgresql" ... }
#
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ═══════════════════════════════════════════════════════════
# NEXTAUTH (required)
# ═══════════════════════════════════════════════════════════
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="codeinsight_super_secret_key_12345"
# For local dev:
NEXTAUTH_URL="http://localhost:3000"
# For Vercel: set NEXTAUTH_URL to your deployment URL
# NEXTAUTH_URL="https://your-app.vercel.app"

# ═══════════════════════════════════════════════════════════
# GITHUB OAuth (optional — for private repo analysis)
# ═══════════════════════════════════════════════════════════
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
# For Vercel: https://your-app.vercel.app/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ═══════════════════════════════════════════════════════════
# GOOGLE OAuth (optional)
# ═══════════════════════════════════════════════════════════
# Create at: https://console.cloud.google.com/
# Callback URL: http://localhost:3000/api/auth/callback/google
# For Vercel: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_ID=""
GOOGLE_SECRET=""
