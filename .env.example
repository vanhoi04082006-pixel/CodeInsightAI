# CodeInsight AI — Environment Variables (Local Development Only)
# Copy this file to `.env` and adjust as needed.
# On Windows (cmd):  copy .env.example .env
# On Windows (PS):   Copy-Item .env.example .env
# On macOS/Linux:    cp .env.example .env

# SQLite database location (relative to project root).
# Prisma will create the file on first `bun run db:push`.
DATABASE_URL="file:./db/custom.db"

# NextAuth secret (random string for session encryption)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="codeinsight_super_secret_key_12345"
NEXTAUTH_URL="http://localhost:3000"

# --- GITHUB OAuth (optional — for private repo analysis) ---
# https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# --- GOOGLE OAuth (optional) ---
# https://console.cloud.google.com/
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_ID=""
GOOGLE_SECRET=""
