# CodeInsight AI — Environment Variables
#
# LOCAL:  cp .env.example .env  → fill in GITHUB_ID / GITHUB_SECRET
# PROD:    Set the same vars in Vercel → Settings → Environment Variables
#          (Use "Production" + "Preview" environments)
#
# After editing locally:  bun run db:push   (creates SQLite tables)
# After editing on Vercel: set DATABASE_URL + run `bun run db:push:prod`
#                          from your local machine with the prod DATABASE_URL.

# ═══════════════════════════════════════════════════════════
# ENVIRONMENT SEPARATION
# ═══════════════════════════════════════════════════════════
# Determines which providers are shown, whether localStorage keys are
# stripped, and other behaviour in lib/env.ts.
#   Local:  APP_ENV=development  +  NEXT_PUBLIC_APP_ENV=development
#   Prod:   APP_ENV=production   +  NEXT_PUBLIC_APP_ENV=production
APP_ENV="development"
NEXT_PUBLIC_APP_ENV="development"

# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════
# LOCAL: SQLite (zero setup). The schema is prisma/schema.prisma (sqlite).
DATABASE_URL="file:./db/custom.db"

# PRODUCTION: PostgreSQL on Neon. The schema is prisma/schema.prod.prisma
# (postgresql). The Vercel build picks it up via PRISMA_SCHEMA env var.
# 1. Create Neon project: https://neon.tech
# 2. Copy connection string
# 3. Set DATABASE_URL on Vercel + locally run:
#    PRISMA_SCHEMA=prisma/schema.prod.prisma DATABASE_URL="postgresql://..." bunx prisma db push
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ═══════════════════════════════════════════════════════════
# NEXTAUTH (required)
# ═══════════════════════════════════════════════════════════
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change_me_to_a_random_32_char_string"
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): set to your deployment URL
# NEXTAUTH_URL="https://code-insight-ai-six.vercel.app"

# ═══════════════════════════════════════════════════════════
# GITHUB OAuth (required — for user login)
# ═══════════════════════════════════════════════════════════
# Create at: https://github.com/settings/developers
# Callback URL (local):  http://localhost:3000/api/auth/callback/github
# Callback URL (prod):   https://code-insight-ai-six.vercel.app/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ═══════════════════════════════════════════════════════════
# PLATFORM AI (optional — for "Platform AI" mode where users don't need their own keys)
# ═══════════════════════════════════════════════════════════
# Recommended: OpenRouter (1 key, 100+ models)
# Your key is NEVER exposed to the frontend — used server-side only.
PLATFORM_AI_API_KEY=""
PLATFORM_AI_BASE_URL="https://openrouter.ai/api/v1"
PLATFORM_AI_MODEL="anthropic/claude-3.5-sonnet"
PLATFORM_AI_PROVIDER="openrouter"

# ═══════════════════════════════════════════════════════════
# STRIPE (optional — for billing/subscriptions)
# ═══════════════════════════════════════════════════════════
# https://dashboard.stripe.com/apikeys
# Test mode keys for development, live keys for production
STRIPE_SECRET_KEY=""
# Webhook secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=""
# Price IDs from Stripe Dashboard → Products
STRIPE_PRICE_PRO=""
STRIPE_PRICE_TEAM=""

# ═══════════════════════════════════════════════════════════
# AUTH DEBUG (optional — verbose NextAuth logs in dev)
# ═══════════════════════════════════════════════════════════
# Set to "1" to enable verbose NextAuth debug logs in development.
AUTH_DEBUG=""
