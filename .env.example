# CodeInsight AI — Environment Variables
#
# This single .env is used for BOTH local development AND production (Vercel).
# The database is PostgreSQL on Neon — local + prod use the same DB engine.
#
# On Vercel, set the same vars in Project Settings → Environment Variables.

# ═══════════════════════════════════════════════════════════
# ENVIRONMENT SEPARATION
# ═══════════════════════════════════════════════════════════
# Local:  development
# Prod:   production
APP_ENV="development"
NEXT_PUBLIC_APP_ENV="development"

# ═══════════════════════════════════════════════════════════
# DATABASE (PostgreSQL on Neon — used for local + prod)
# ═══════════════════════════════════════════════════════════
# 1. Create Neon project: https://neon.tech
# 2. Copy connection string
# 3. Set DATABASE_URL here (local) + on Vercel env vars (prod)
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ═══════════════════════════════════════════════════════════
# NEXTAUTH (required)
# ═══════════════════════════════════════════════════════════
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change_me_to_a_random_32_char_string"
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): set to your deployment URL
# NEXTAUTH_URL="https://your-app.vercel.app"

# ═══════════════════════════════════════════════════════════
# GITHUB OAuth (required — for user login)
# ═══════════════════════════════════════════════════════════
# Create at: https://github.com/settings/developers
# Callback URL (local):  http://localhost:3000/api/auth/callback/github
# Callback URL (prod):   https://your-app.vercel.app/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ═══════════════════════════════════════════════════════════
# PLATFORM AI (optional — for "Platform AI" mode)
# ═══════════════════════════════════════════════════════════
# Recommended: OpenRouter (1 key, 100+ models)
PLATFORM_AI_API_KEY=""
PLATFORM_AI_BASE_URL="https://openrouter.ai/api/v1"
PLATFORM_AI_MODEL="anthropic/claude-3.5-sonnet"
PLATFORM_AI_PROVIDER="openrouter"

# ═══════════════════════════════════════════════════════════
# STRIPE (optional — for billing)
# ═══════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_TEAM=""

# ═══════════════════════════════════════════════════════════
# AUTH DEBUG (optional — verbose NextAuth logs in dev)
# ═══════════════════════════════════════════════════════════
AUTH_DEBUG=""
