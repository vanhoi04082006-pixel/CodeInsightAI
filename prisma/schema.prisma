// CodeInsight AI — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id                 String   @id @default(cuid())
  repoUrl            String
  repoOwner          String
  repoName           String
  repoBranch         String   @default("main")
  status             String   @default("completed") // completed | analyzing | failed
  
  // Scores
  overallScore       Int      @default(0)
  securityScore      Int      @default(0)
  performanceScore   Int      @default(0)
  architectureScore  Int      @default(0)
  maintainabilityScore Int    @default(0)
  codeQualityScore   Int      @default(0)
  
  // Metadata
  primaryLanguage    String?
  totalFiles         Int      @default(0)
  totalLines         Int      @default(0)
  languages          String   @default("[]") // JSON array
  frameworks         String   @default("[]") // JSON array
  
  // Full report JSON
  report             String   @default("{}") // JSON blob of full analysis
  
  // Parsed repo data (structured memory)
  parsedData         String? // JSON of ParsedRepository
  
  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  messages           ChatMessage[]
  fileSummaries      FileSummary[]

  @@index([repoUrl])
  @@index([createdAt])
  @@index([repoOwner, repoName])
}

model ChatMessage {
  id          String   @id @default(cuid())
  analysisId  String
  role        String   // user | assistant
  content     String
  createdAt   DateTime @default(now())

  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

// Structured file-level memory — persists per-file summaries + symbols
model FileSummary {
  id          String   @id @default(cuid())
  analysisId  String
  path        String
  language    String
  lines       Int      @default(0)
  complexity  Int      @default(0)
  description String   @default("")
  imports     String   @default("[]")  // JSON array
  exports     String   @default("[]")  // JSON array
  functions   String   @default("[]")  // JSON array
  classes     String   @default("[]")  // JSON array
  components  String   @default("[]")  // JSON array
  routes      String   @default("[]")  // JSON array
  issues      Int      @default(0)
  createdAt   DateTime @default(now())

  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([path])
}

// User settings persistence (survives reload)
model UserSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // JSON
  updatedAt   DateTime @updatedAt
}

// ==========================================
// THÊM: NEXTAUTH MODELS (Dùng để quản lý User & Token đăng nhập)
// ==========================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}