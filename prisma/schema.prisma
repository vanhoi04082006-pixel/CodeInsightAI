// CodeInsight AI — Prisma schema (PostgreSQL)
//
// This single schema is used for BOTH local development AND production.
// Local dev connects to Neon (or a local Postgres if you prefer), and
// production connects to Neon via the DATABASE_URL env var on Vercel.
//
// We previously split this into schema.prisma (sqlite) + schema.prod.prisma
// (postgresql), but Prisma's runtime client only reads schema.prisma —
// the PRISMA_SCHEMA env var is only respected by the CLI at generate time,
// not by the generated client at runtime. This caused production to fail
// with "the URL must start with the protocol `file:`" because the runtime
// was loading the sqlite schema while DATABASE_URL was postgresql.
//
// Migrating to PostgreSQL for local dev is fine — Neon's free tier is more
// than enough, and it means local + prod use the exact same DB engine
// (no more "works on my machine" SQLite vs Postgres quirks).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER & AUTH (NextAuth.js)
// ==========================================

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  // SaaS fields
  plan            String    @default("free") // free | pro | team | enterprise
  stripeCustomerId String?
  trialEndsAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  analyses        Analysis[]
  credentials     ProviderCredential[]
  usageRecords    UsageRecord[]
  settings        UserSettings[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// ANALYSIS & CHAT (multi-tenant via userId)
// ==========================================

model Analysis {
  id                 String   @id @default(cuid())
  userId             String?
  repoUrl            String
  repoOwner          String
  repoName           String
  repoBranch         String   @default("main")
  status             String   @default("completed")

  overallScore       Int      @default(0)
  securityScore      Int      @default(0)
  performanceScore   Int      @default(0)
  architectureScore  Int      @default(0)
  maintainabilityScore Int    @default(0)
  codeQualityScore   Int      @default(0)

  primaryLanguage    String?
  totalFiles         Int      @default(0)
  totalLines         Int      @default(0)
  languages          String   @default("[]")
  frameworks         String   @default("[]")
  report             String   @default("{}")
  parsedData         String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           ChatMessage[]
  fileSummaries      FileSummary[]

  @@index([userId])
  @@index([repoUrl])
  @@index([createdAt])
  @@index([repoOwner, repoName])
}

model ChatMessage {
  id          String   @id @default(cuid())
  analysisId  String
  role        String
  content     String
  createdAt   DateTime @default(now())

  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model FileSummary {
  id          String   @id @default(cuid())
  analysisId  String
  path        String
  language    String
  lines       Int      @default(0)
  complexity  Int      @default(0)
  description String   @default("")
  imports     String   @default("[]")
  exports     String   @default("[]")
  functions   String   @default("[]")
  classes     String   @default("[]")
  components  String   @default("[]")
  routes      String   @default("[]")
  issues      Int      @default(0)
  createdAt   DateTime @default(now())

  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([path])
}

// ==========================================
// USER SETTINGS (multi-tenant)
// ==========================================

model UserSettings {
  id          String   @id @default(cuid())
  userId      String?
  key         String
  value       String
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// ==========================================
// PROVIDER CREDENTIALS (server-side encrypted API keys)
// ==========================================

model ProviderCredential {
  id              String   @id @default(cuid())
  userId          String
  providerId      String   // openrouter | openai | anthropic | etc.
  label           String
  encryptedApiKey String   // AES-256 encrypted
  baseUrl         String
  model           String
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(4096)
  streaming       Boolean  @default(true)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, providerId, label])
}

// ==========================================
// USAGE TRACKING (quota enforcement)
// ==========================================

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  type        String   // analysis | chat | agent_task
  month       String   // "2026-07" format
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month])
  @@unique([userId, type, month])
}

// ==========================================
// AGENT MEMORY & EVENTS
// ==========================================

model MemoryEntry {
  id          String   @id @default(cuid())
  category    String
  key         String
  value       String   @default("{}")
  tags        String   @default("[]")
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accessCount Int      @default(0)

  @@index([category])
  @@index([repoUrl])
  @@index([key])
  @@unique([category, key, repoUrl])
}

model AgentTask {
  id          String   @id @default(cuid())
  taskId      String   @unique
  kind        String
  title       String
  status      String
  assignedAgent String?
  priority    String   @default("medium")
  input       String   @default("{}")
  output      String?
  error       String?
  progress    Int      @default(0)
  attempts    Int      @default(0)
  parentTaskId String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status])
  @@index([kind])
  @@index([createdAt])
}

model AgentEvent {
  id          String   @id @default(cuid())
  taskId      String?
  agentId     String?
  type        String
  message     String
  level       String   @default("info")
  data        String?
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([agentId])
  @@index([createdAt])
}
