/db/*
!/db/.gitkeep
*.db
*.db-journal

# Server launcher logs/state
watchdog.log
dev.out.log
start-dev.sh
watch-dev.sh

# Local provider config / secrets
provider-config.json
# Runtime/sandbox artifacts
/.zscripts/
/tool-results/
*.pid
agent-ctx/
